# Basic Navigation Test
# Tests goto, wait, and screenshot commands

-- meta.yaml --
name: Basic Navigation
description: Test basic navigation commands
version: "1.0"
headless: false
timeout: 30s

-- main.cdp --
# Navigate to a simple page
goto https://www.google.com

# Wait for the page to load
wait 2s

# Take a screenshot
screenshot /tmp/google.png

log "Basic navigation test completed"
